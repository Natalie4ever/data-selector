# =============================================================
# Data Selector 多数据源配置示例
#
# 命名规则：
#   DS_<PROJECT>_NAME  - 显示名称
#   DS_<PROJECT>_TYPE - 数据库类型：sqlite/mysql/postgres/oracle/sqlserver
#   DS_<PROJECT>_HOST - 主机地址
#   DS_<PROJECT>_PORT - 端口（可选，使用默认值时可省略）
#   DS_<PROJECT>_DB   - 数据库名/文件路径
#   DS_<PROJECT>_USER - 用户名
#   DS_<PROJECT>_PASS - 明文密码（调试用，不推荐生产环境使用）
#   DS_<PROJECT>_PASS_ENC - 加密后的密文密码（推荐，配合 DS_DECRYPT_KEY 使用）
#
# Oracle 额外配置（二选一）：
#   DS_<PROJECT>_SID     - 实例 ID
#   DS_<PROJECT>_SERVICE - 服务名
# =============================================================


# =============================================================
# 加密密钥（AES-256-CBC）
# =============================================================
# 这两个密钥必须配置才能解密密码
# 注意：生产环境推荐通过系统环境变量注入，不要写在文件里
DS_DECRYPT_KEY=your-base64-encoded-32-byte-key-here
DS_DECRYPT_IV=your-base64-encoded-16-byte-iv-here


# =============================================================
# 示例 1：SQLite 文件数据库（外部项目）
# =============================================================
DS_PROJ1_NAME=项目A - 本地 SQLite
DS_PROJ1_TYPE=sqlite
DS_PROJ1_DB=C:/path/to/project_a/database.db
# SQLite 不需要用户名/密码，PASS/PASS_ENC 留空


# =============================================================
# 示例 2：Oracle 数据库
# =============================================================
DS_PROJ2_NAME=项目B - Oracle
DS_PROJ2_TYPE=oracle
DS_PROJ2_HOST=192.168.1.100
DS_PROJ2_PORT=1521
DS_PROJ2_SERVICE=ORCLPDB1  # 服务名方式（推荐）
# 或者使用 SID: DS_PROJ2_SID=ORCL
DS_PROJ2_USER=readonly_user
# 加密后的密码（由 encrypt_tool.py 生成）
DS_PROJ2_PASS_ENC=GkXfYZJQmF2Z0pHZ...


# =============================================================
# 示例 3：SQL Server
# =============================================================
DS_PROJ3_NAME=项目C - SQL Server
DS_PROJ3_TYPE=sqlserver
DS_PROJ3_HOST=192.168.1.101
DS_PROJ3_PORT=1433
DS_PROJ3_DB=ProjectCDb
DS_PROJ3_USER=sa
DS_PROJ3_PASS_ENC=abcdefg12345...


# =============================================================
# 示例 4：MySQL
# =============================================================
DS_PROJ4_NAME=项目D - MySQL
DS_PROJ4_TYPE=mysql
DS_PROJ4_HOST=192.168.1.102
DS_PROJ4_PORT=3306
DS_PROJ4_DB=projectd
DS_PROJ4_USER=readonly
DS_PROJ4_PASS_ENC=xyz...


# =============================================================
# 示例 5：PostgreSQL
# =============================================================
DS_PROJ5_NAME=项目E - PostgreSQL
DS_PROJ5_TYPE=postgres
DS_PROJ5_HOST=192.168.1.103
DS_PROJ5_PORT=5432
DS_PROJ5_DB=projecte
DS_PROJ5_USER=postgres
DS_PROJ5_PASS_ENC=abc123...


# =============================================================
# 默认内置数据库（data.db）
# =============================================================
DS_DEFAULT_TYPE=sqlite
DS_DEFAULT_DB=./backend/data.db
